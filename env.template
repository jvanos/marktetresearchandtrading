# Copy this file to .env and fill in real values. .env is gitignored.
# In cloud routines, set these as environment variables ON THE ROUTINE
# ITSELF -- do NOT create a .env file in the cloud (see CLAUDE.md / Part 7
# of the setup guide for why).

# Alpaca -- PAPER TRADING by default. This bot places real orders; switch
# to live only when you're ready (https://api.alpaca.markets/v2) and
# understand the risk.
ALPACA_ENDPOINT=https://paper-api.alpaca.markets/v2
ALPACA_DATA_ENDPOINT=https://data.alpaca.markets/v2
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Daily-loss circuit breaker: fraction of last close's equity that, if lost
# in a day, blocks new BUY orders (sells/closes are never blocked).
MAX_DAILY_LOSS_PCT=0.05

# Perplexity (research)
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=sonar

# ClickUp (notifications -- posts to a Chat channel)
CLICKUP_API_KEY=your_clickup_api_key_here
CLICKUP_WORKSPACE_ID=your_clickup_workspace_id_here
CLICKUP_CHANNEL_ID=your_clickup_channel_id_here